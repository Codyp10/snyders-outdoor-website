---
import business from '../data/business.json';

interface CTA {
  text: string;
  href: string;
}

interface Props {
  eyebrow?: string;
  headline: string;
  subhead?: string;
  heroImage?: string;
  heroAlt?: string;
  variant?: 'home' | 'service' | 'location' | 'about' | 'contact' | 'emergency';
  primaryCTA?: CTA;
  secondaryCTA?: CTA;
}

const {
  eyebrow,
  headline,
  subhead,
  variant = 'service',
  primaryCTA = { text: 'Call Now', href: `tel:${business.phoneTel}` },
  secondaryCTA,
} = Astro.props;

const heightClass = {
  home: 'min-h-[600px] md:min-h-[640px]',
  service: 'min-h-[420px] md:min-h-[460px]',
  location: 'min-h-[420px] md:min-h-[460px]',
  about: 'min-h-[360px] md:min-h-[400px]',
  contact: 'min-h-[280px] md:min-h-[320px]',
  emergency: 'min-h-[420px] md:min-h-[460px]',
}[variant];

const isEmergency = variant === 'emergency';

// PLACEHOLDER: replace gradient bg with <Image> hero when asset lands.
// Each page's heroImage frontmatter field will drive the src.
---

<section
  class:list={[
    'relative flex items-center',
    heightClass,
    isEmergency
      ? 'bg-[linear-gradient(135deg,#7a1d1d_0%,#3A6B44_100%)]'
      : 'bg-[linear-gradient(135deg,#3A6B44_0%,#1f3a26_100%)]',
  ]}
>
  <!-- PLACEHOLDER: hero background treatment in lieu of photo -->
  <div class="absolute inset-0 bg-black/30" aria-hidden="true"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20 w-full">
    {
      eyebrow && (
        <p
          class:list={[
            'uppercase tracking-widest text-xs font-semibold mb-4',
            isEmergency ? 'text-orange-300' : 'text-brand-light',
          ]}
        >
          {eyebrow}
        </p>
      )
    }

    <h1 class="font-heading font-extrabold text-white text-3xl sm:text-4xl md:text-5xl leading-tight max-w-4xl">
      {headline}
    </h1>

    {
      subhead && (
        <p class="mt-5 text-base md:text-lg text-white/85 leading-relaxed max-w-2xl">
          {subhead}
        </p>
      )
    }

    <div class="mt-8 flex flex-col sm:flex-row gap-3">
      <a
        href={primaryCTA.href}
        class="inline-flex items-center justify-center gap-2 bg-orange-500 hover:bg-orange-600 text-white font-bold px-6 md:px-8 py-4 rounded-lg text-base md:text-lg min-h-12 focus:outline-none focus:ring-2 focus:ring-white/60"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
        </svg>
        {primaryCTA.text}
      </a>
      {
        secondaryCTA && (
          <a
            href={secondaryCTA.href}
            class="inline-flex items-center justify-center border-2 border-white text-white hover:bg-white/10 font-bold px-6 md:px-8 py-4 rounded-lg text-base md:text-lg min-h-12 focus:outline-none focus:ring-2 focus:ring-white/60"
          >
            {secondaryCTA.text}
          </a>
        )
      }
    </div>
  </div>
</section>
