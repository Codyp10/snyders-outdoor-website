---
import business from '../data/business.json';
---

<div class="lg:hidden fixed bottom-0 inset-x-0 z-40 bg-brand-dark border-t border-white/10 shadow-[0_-4px_12px_rgba(0,0,0,0.2)]">
  <div class="flex gap-2 p-3">
    <a
      href={`tel:${business.phoneTel}`}
      class="flex-[3] inline-flex items-center justify-center gap-2 bg-orange-500 hover:bg-orange-600 text-white font-bold px-4 py-3 rounded-lg text-base min-h-11"
    >
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
      </svg>
      Call Now
    </a>
    <a
      href="/contact"
      class="flex-[2] inline-flex items-center justify-center bg-brand hover:bg-brand/80 text-white font-bold px-4 py-3 rounded-lg text-sm min-h-11 border border-white/20"
    >
      Free Estimate
    </a>
  </div>
</div>
