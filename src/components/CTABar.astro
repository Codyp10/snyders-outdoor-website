---
import business from '../data/business.json';

interface Props {
  headline?: string;
  subhead?: string;
  variant?: 'default' | 'emergency';
}

const {
  headline = 'Ready to get started? Call us today.',
  subhead,
  variant = 'default',
} = Astro.props;

const isEmergency = variant === 'emergency';
---

<section class="bg-brand-dark py-14 md:py-20">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="font-heading font-bold text-white text-2xl md:text-4xl leading-tight">
      {headline}
    </h2>
    {subhead && <p class="mt-4 text-white/80 text-base md:text-lg">{subhead}</p>}
    <div class="mt-7 flex flex-col sm:flex-row gap-3 justify-center">
      <a
        href={`tel:${business.phoneTel}`}
        class="inline-flex items-center justify-center gap-2 bg-orange-500 hover:bg-orange-600 text-white font-bold px-8 py-4 rounded-lg text-base md:text-lg min-h-12 focus:outline-none focus:ring-2 focus:ring-white/60"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
        </svg>
        Call Now
      </a>
      {
        !isEmergency && (
          <a
            href="/contact"
            class="inline-flex items-center justify-center border-2 border-white text-white hover:bg-white/10 font-bold px-8 py-4 rounded-lg text-base md:text-lg min-h-12 focus:outline-none focus:ring-2 focus:ring-white/60"
          >
            Get a Free Estimate
          </a>
        )
      }
    </div>
  </div>
</section>
