---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<div
  class:list={[
    'prose prose-lg max-w-none',
    'text-gray-700 leading-relaxed',
    '[&>p]:mb-4 [&>p:last-child]:mb-0',
    '[&>h2]:font-heading [&>h2]:font-bold [&>h2]:text-gray-900 [&>h2]:text-2xl [&>h2]:md:text-3xl [&>h2]:mt-8 [&>h2]:mb-4',
    '[&>h3]:font-heading [&>h3]:font-bold [&>h3]:text-gray-900 [&>h3]:text-xl [&>h3]:mt-6 [&>h3]:mb-3',
    '[&>ul]:list-disc [&>ul]:pl-6 [&>ul]:mb-4 [&>ul>li]:mb-2',
    '[&>ol]:list-decimal [&>ol]:pl-6 [&>ol]:mb-4 [&>ol>li]:mb-2',
    '[&_a]:text-brand [&_a]:font-semibold [&_a:hover]:text-brand-dark [&_a]:underline [&_a]:underline-offset-4',
    className,
  ]}
>
  <slot />
</div>
