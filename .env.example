# Copy to .env.local for local dev, and set in Vercel project settings for production.
# Any variable prefixed with PUBLIC_ is exposed to the browser.

# Google Tag Manager container ID (GTM-XXXXXXX). Leave empty to disable tracking.
# All other tracking (GA4, CallRail, Microsoft Clarity) fires through GTM — do not add
# separate IDs here.
PUBLIC_GTM_ID=
